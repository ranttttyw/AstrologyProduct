.profile-container {
  min-height: 100vh;
  padding: 30rpx;
  background: #F5F5F5;
}

/* 用户信息卡片 */
.info-card {
  background: linear-gradient(135deg, #7C5CFC 0%, #B06AB3 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  color: #fff;
}
.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 36rpx;
}
.sun-sign-badge {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 32rpx;
}
.sun-sign-emoji { font-size: 56rpx; }
.sun-sign-name { font-size: 24rpx; margin-top: 4rpx; opacity: 0.9; }
.birth-info { flex: 1; }
.birth-line { display: block; font-size: 28rpx; opacity: 0.85; line-height: 1.6; }
.birth-line.city { font-size: 24rpx; opacity: 0.65; }

/* 三大星座 */
.big-three {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
}
.big-three-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.bt-label { font-size: 22rpx; opacity: 0.7; }
.bt-sign { font-size: 30rpx; font-weight: 600; margin-top: 8rpx; }
.bt-degree { font-size: 22rpx; opacity: 0.6; margin-top: 4rpx; }
.bt-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.25);
}

/* 行星详情卡片 */
.planet-card {
  background: #fff;
  border-radius: 24rpx;
  margin-top: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.planet-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}
.planet-list { }
.planet-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.planet-row:last-child { border-bottom: none; }
.planet-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.planet-emoji { font-size: 32rpx; }
.planet-name { font-size: 28rpx; color: #666; }
.planet-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.planet-sign {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}
.planet-degree {
  font-size: 24rpx;
  color: #999;
  min-width: 80rpx;
  text-align: right;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}
.empty-emoji { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-title { font-size: 36rpx; font-weight: 600; color: #333; }
.empty-desc { font-size: 28rpx; color: #999; margin-top: 12rpx; text-align: center; }

/* 表单 */
.form-section { margin-top: 30rpx; }
.form-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}
.form-item {
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}
.form-item:last-child { border-bottom: none; }
.form-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}
.picker-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.picker-text { font-size: 30rpx; color: #333; }
.picker-text.placeholder { color: #ccc; }
.picker-arrow { font-size: 32rpx; color: #ccc; }
.form-input {
  font-size: 30rpx;
  width: 100%;
}

/* 按钮 */
.primary-btn {
  background: #7C5CFC;
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-top: 40rpx;
}
.primary-btn:active { opacity: 0.85; }
.secondary-btn {
  color: #7C5CFC;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  margin-top: 24rpx;
}
