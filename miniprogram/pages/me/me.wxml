<!-- 我的页面 -->
<view class="me-container">

  <!-- 用户头像区域 -->
  <view class="user-header">
    <view class="avatar-circle">
      <text class="avatar-emoji">🌙</text>
    </view>

    <!-- 昵称（点击编辑） -->
    <view class="nickname-row" wx:if="{{!editingNickname}}" bindtap="startEditNickname">
      <text class="user-name">{{nickname || '点击设置昵称'}}</text>
      <text class="edit-icon">✏️</text>
    </view>

    <!-- 编辑昵称 -->
    <view class="nickname-edit" wx:if="{{editingNickname}}">
      <input
        class="nickname-input"
        placeholder="输入你的昵称"
        value="{{nicknameInput}}"
        bindinput="onNicknameInput"
        focus="{{true}}"
        maxlength="20"
        bindconfirm="saveNickname"
      />
      <view class="nickname-save" bindtap="saveNickname">确定</view>
    </view>

    <text class="user-desc" wx:if="{{hasChart}}">{{sunSign}} · 已设置星盘</text>
    <text class="user-desc" wx:else>还没有设置星盘</text>
  </view>

  <!-- 个人资料卡片 -->
  <view class="menu-card">
    <view class="section-title">个人资料</view>

    <!-- 性别 -->
    <view class="info-row">
      <text class="info-label">性别</text>
      <view class="gender-options">
        <view
          class="gender-tag {{gender === '女' ? 'active' : ''}}"
          bindtap="setGender"
          data-val="女"
        >♀ 女</view>
        <view
          class="gender-tag {{gender === '男' ? 'active' : ''}}"
          bindtap="setGender"
          data-val="男"
        >♂ 男</view>
        <view
          class="gender-tag {{gender === '其他' ? 'active' : ''}}"
          bindtap="setGender"
          data-val="其他"
        >其他</view>
      </view>
    </view>

    <!-- 职业 -->
    <view class="info-row">
      <text class="info-label">职业</text>
      <view class="occupation-area" wx:if="{{!editingOccupation}}">
        <text class="occupation-text" bindtap="startEditOccupation">{{occupation || '点击设置'}}</text>
      </view>
      <view class="occupation-edit" wx:if="{{editingOccupation}}">
        <input
          class="occupation-input"
          placeholder="比如：学生、设计师..."
          value="{{occupationInput}}"
          bindinput="onOccupationInput"
          focus="{{true}}"
          maxlength="20"
          bindconfirm="saveOccupation"
        />
        <view class="occupation-save" bindtap="saveOccupation">确定</view>
      </view>
    </view>

    <!-- 常用职业快捷标签 -->
    <view class="quick-tags" wx:if="{{editingOccupation}}">
      <view class="quick-tag" bindtap="pickOccupation" data-val="学生">学生</view>
      <view class="quick-tag" bindtap="pickOccupation" data-val="上班族">上班族</view>
      <view class="quick-tag" bindtap="pickOccupation" data-val="自由职业">自由职业</view>
      <view class="quick-tag" bindtap="pickOccupation" data-val="创业者">创业者</view>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="goToProfile">
      <text class="menu-icon">🔮</text>
      <text class="menu-text">我的星盘</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToChat">
      <text class="menu-icon">💬</text>
      <text class="menu-text">聊天记录</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item">
      <text class="menu-icon">📖</text>
      <text class="menu-text">使用指南</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item">
      <text class="menu-icon">💡</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="footer">
    <text class="footer-text">今天会中奖吗 v0.1.0</text>
  </view>

</view>
