.me-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 40rpx;
}

/* 用户头像区域 */
.user-header {
  background: linear-gradient(135deg, #7C5CFC 0%, #B06AB3 100%);
  padding: 80rpx 30rpx 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}
.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}
.avatar-emoji { font-size: 56rpx; }
.nickname-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.user-name {
  font-size: 36rpx;
  font-weight: 600;
}
.edit-icon { font-size: 24rpx; opacity: 0.7; }
.nickname-edit {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.nickname-input {
  background: rgba(255,255,255,0.25);
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 30rpx;
  color: #fff;
  width: 300rpx;
  text-align: center;
}
.nickname-save {
  background: rgba(255,255,255,0.3);
  border-radius: 24rpx;
  padding: 10rpx 28rpx;
  font-size: 26rpx;
}
.user-desc {
  font-size: 26rpx;
  opacity: 0.75;
}

/* 个人资料卡片 */
.section-title {
  font-size: 28rpx;
  color: #999;
  padding: 24rpx 30rpx 8rpx;
}
.info-row {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.info-label {
  font-size: 30rpx;
  color: #333;
  width: 120rpx;
  flex-shrink: 0;
}

/* 性别选择 */
.gender-options {
  display: flex;
  gap: 16rpx;
  flex: 1;
}
.gender-tag {
  font-size: 26rpx;
  padding: 10rpx 28rpx;
  border-radius: 28rpx;
  background: #F0F0F0;
  color: #666;
}
.gender-tag.active {
  background: linear-gradient(135deg, #7C5CFC, #B06AB3);
  color: #fff;
}

/* 职业编辑 */
.occupation-area {
  flex: 1;
}
.occupation-text {
  font-size: 30rpx;
  color: #666;
}
.occupation-edit {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}
.occupation-input {
  flex: 1;
  font-size: 28rpx;
  padding: 10rpx 20rpx;
  border-bottom: 2rpx solid #7C5CFC;
  color: #333;
}
.occupation-save {
  font-size: 26rpx;
  color: #7C5CFC;
  font-weight: 600;
}

/* 快捷标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 8rpx 30rpx 24rpx;
}
.quick-tag {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  background: #F0ECFF;
  color: #7C5CFC;
}

/* 功能列表 */
.menu-card {
  background: #fff;
  border-radius: 20rpx;
  margin: 24rpx 30rpx 0;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 36rpx; margin-right: 20rpx; }
.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}
.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 版本信息 */
.footer {
  text-align: center;
  margin-top: 60rpx;
}
.footer-text {
  font-size: 24rpx;
  color: #ccc;
}
