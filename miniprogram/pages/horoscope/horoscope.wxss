.horoscope-container {
  min-height: 100vh;
  padding: 30rpx;
  background: #F5F5F5;
}

/* 日期 */
.date-header {
  text-align: center;
  padding: 40rpx 0;
}
.date-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  display: block;
}
.weekday {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

/* 运势卡片 */
.horoscope-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.greeting-row { margin-bottom: 16rpx; }
.greeting-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #7C5CFC;
}
.summary-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  margin-bottom: 24rpx;
}

/* 维度评分 */
.dimension-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.dim-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: #F8F6FF;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
}
.dim-label {
  font-size: 24rpx;
  color: #666;
}
.dim-stars {
  font-size: 22rpx;
  color: #FFB800;
  letter-spacing: 2rpx;
}

/* 幸运区域 */
.lucky-section {
  display: flex;
  gap: 24rpx;
  margin-bottom: 16rpx;
}
.lucky-item {
  font-size: 26rpx;
  color: #888;
}

/* 小贴士 */
.tip-section {
  font-size: 26rpx;
  color: #7C5CFC;
  background: #F8F6FF;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  line-height: 1.5;
}

.card-icon {
  font-size: 48rpx;
  margin-bottom: 24rpx;
}
.card-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

.empty-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}
.link-btn {
  color: #7C5CFC;
  font-size: 28rpx;
  margin-top: 24rpx;
}

/* 跳转聊天 */
.action-section {
  margin-top: 40rpx;
}
.action-btn {
  background: linear-gradient(135deg, #7C5CFC, #B06AB3);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 48rpx;
  font-size: 30rpx;
}
.action-btn:active { opacity: 0.85; }
