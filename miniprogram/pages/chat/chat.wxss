.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F5F5F5;
}

/* 引导横幅 */
.guide-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #7C5CFC, #B06AB3);
  color: #fff;
}
.guide-text { font-size: 26rpx; }
.guide-arrow { font-size: 26rpx; opacity: 0.8; }

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

/* 单条消息 */
.message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 28rpx;
}
.message.user { flex-direction: row-reverse; }

/* 头像 */
.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  flex-shrink: 0;
}
.bot-avatar { background: #EDE8FF; }
.user-avatar { background: #E8F4FD; }

/* 气泡 */
.bubble {
  max-width: 65%;
  padding: 20rpx 28rpx;
  border-radius: 24rpx;
  margin: 0 16rpx;
  font-size: 30rpx;
  line-height: 1.7;
  word-wrap: break-word;
}
.bot-bubble {
  background: #fff;
  color: #333;
  border-top-left-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.user-bubble {
  background: #7C5CFC;
  color: #fff;
  border-top-right-radius: 6rpx;
}

/* 加载动画 */
.loading-bubble { padding: 24rpx 36rpx; }
.loading-dots { display: flex; gap: 12rpx; }
.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #7C5CFC;
  animation: bounce 1.2s infinite ease-in-out;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1.1); }
}

/* 快捷问题 */
.quick-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 16rpx 30rpx;
  justify-content: center;
}
.quick-btn {
  background: #fff;
  border: 2rpx solid #EDE8FF;
  border-radius: 40rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #7C5CFC;
}
.quick-btn:active { background: #EDE8FF; }

/* 输入框 */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}
.message-input {
  flex: 1;
  height: 76rpx;
  background: #F5F5F5;
  border-radius: 38rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}
.send-btn {
  margin-left: 16rpx;
  background: #ddd;
  color: #fff;
  font-size: 28rpx;
  padding: 0 36rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  text-align: center;
}
.send-btn.active {
  background: #7C5CFC;
}

/* 今日运势欢迎卡片 */
.welcome-card {
  max-width: 75%;
  background: linear-gradient(135deg, #F8F6FF 0%, #FFF5F9 100%);
  border-radius: 24rpx;
  border-top-left-radius: 6rpx;
  padding: 28rpx 32rpx;
  margin: 0 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(124, 92, 252, 0.08);
}
.welcome-greeting {
  font-size: 32rpx;
  font-weight: 600;
  color: #7C5CFC;
  margin-bottom: 16rpx;
}
.welcome-summary {
  font-size: 28rpx;
  line-height: 1.7;
  color: #444;
  margin-bottom: 20rpx;
}

/* 评分网格 */
.score-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.score-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(124, 92, 252, 0.08);
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
}
.score-label {
  font-size: 22rpx;
  color: #666;
}
.score-stars {
  font-size: 20rpx;
  color: #FFB800;
  letter-spacing: 2rpx;
}

/* 幸运标签 */
.lucky-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.lucky-tag {
  font-size: 24rpx;
  color: #888;
  background: rgba(124, 92, 252, 0.06);
  border-radius: 8rpx;
  padding: 6rpx 14rpx;
}

/* 小贴士 */
.welcome-tip {
  font-size: 24rpx;
  color: #7C5CFC;
  background: rgba(124, 92, 252, 0.06);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  line-height: 1.5;
}
